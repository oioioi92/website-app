# Postgres（用 schema.postgres.prisma 时必须以此格式；否则 migrate:pg 会报 P1012）
DATABASE_URL="postgresql://user:pass@localhost:5432/website"
# 本地零依赖开发可用 SQLite（仅配合 schema.sqlite.prisma）：DATABASE_URL="file:./dev.db"
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="change_me_123"
SESSION_SECRET="replace_with_long_random_string"
CSRF_SECRET="replace_with_long_random_string"
# ----- Live Chat（需同时部署 services/chat-server 并配置 Nginx 反代 /chat/、/ws-visitor、/ws-admin） -----
CHAT_ADMIN_JWT_SECRET="replace_with_long_random_string"
CHAT_SERVER_INTERNAL_URL="http://127.0.0.1:4000"
# ----- 对象存储（S3 兼容即可：Cloudflare R2、阿里云 OSS、腾讯云 COS、七牛、AWS S3 等） -----
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your_key"
R2_SECRET_ACCESS_KEY="your_secret"
R2_BUCKET="my-brand-assets"
R2_PUBLIC_BASE_URL="https://cdn.my-domain.com"
# 非 R2 时可选：阿里云填 oss-cn-hangzhou，腾讯云填 ap-guangzhou，AWS 填 us-east-1 等
# R2_REGION="auto"
RATE_LIMIT_ENABLED="1"
RATE_LIMIT_RPM="120"
INTERNAL_TEST_MODE="1"
USE_HOME_V3="0"
# 后台与前台域名（用于跳转互连：前台点 /admin 跳到后台，后台点「打开前台」跳到前台）
FRONTEND_DOMAIN="admin1167.com"
ADMIN_DOMAIN="admin1167.net"
# 【线上必填】后台「打开前台」+ 图片转网址拼完整链接。填前台域名，如 https://admin1167.com
NEXT_PUBLIC_FRONTEND_URL="https://admin1167.com"
# 【线上必填·上传图片】未配置 R2 时，上传接口用此地址返回图片链接。建议与 NEXT_PUBLIC_FRONTEND_URL 一致。
# 详见 docs/图片转网址-部署检查清单.md
NEXT_PUBLIC_UPLOAD_PUBLIC_URL="https://admin1167.com"
# 备用：若未设置 NEXT_PUBLIC_UPLOAD_PUBLIC_URL，则用此项（不推荐，会暴露后台域名）
# NEXT_PUBLIC_APP_URL="https://admin1167.net"
# 前台/后台连 chat 的地址。与主站同域名时留空或填主站 URL，如 https://admin1167.com
NEXT_PUBLIC_CHAT_SERVER_URL=""
# WhatsApp Webhook 验签（Meta 应用密钥，用于校验 X-Hub-Signature-256；不配置则 POST 不验签）
# WHATSAPP_APP_SECRET=""
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=""